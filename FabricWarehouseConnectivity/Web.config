<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <!--
    ============================================================================
    Fabric Warehouse connection strings.
    Fabric supports Microsoft Entra ID authentication ONLY. Every connection
    string that authenticates directly MUST include an
    "Authentication=Active Directory ..." keyword.
    Replace the <<placeholders>> with your own values.
    ============================================================================
  -->
  <connectionStrings>

    <!-- Service Principal (server-hosted, non-interactive). User Id = Entra app
         (client) ID. The client SECRET is NOT stored here: the code injects it at
         runtime from the environment variable / App Service setting FABRIC_SP_SECRET
         (see FabricWarehouseConnector.GetConnectionString). Used by TestConnection.aspx. -->
    <add name="FabricWarehouse"
         providerName="Microsoft.Data.SqlClient"
         connectionString="Server=<<your-warehouse>>.datawarehouse.fabric.microsoft.com;Database=<<your-database>>;Authentication=Active Directory Service Principal;User Id=<<your-client-id>>;Encrypt=True;TrustServerCertificate=False;Connect Timeout=60;" />

    <!-- Per-user token connection (no auth keyword). The home page (Default.aspx)
         acquires a Microsoft Entra token for the SIGNED-IN user and assigns it to
         SqlConnection.AccessToken so Fabric applies row-level security per user. -->
    <add name="FabricWarehouseToken"
         providerName="Microsoft.Data.SqlClient"
         connectionString="Server=<<your-warehouse>>.datawarehouse.fabric.microsoft.com;Database=<<your-database>>;Encrypt=True;TrustServerCertificate=False;Connect Timeout=60;" />

    <!-- Local dev only: interactive sign-in (pops an MFA browser prompt).
         Runs from Visual Studio / IIS Express. Will NOT work under IIS. -->
    <add name="FabricWarehouseInteractive"
         providerName="Microsoft.Data.SqlClient"
         connectionString="Server=<<your-warehouse>>.datawarehouse.fabric.microsoft.com;Database=<<your-database>>;Authentication=Active Directory Interactive;Encrypt=True;TrustServerCertificate=False;Connect Timeout=60;" />

  </connectionStrings>

  <appSettings>
    <!-- Optional: a sample table/view for TestConnection.aspx to query.
         Leave empty to only run SELECT @@VERSION. -->
    <add key="Fabric:SampleQuery" value="SELECT TOP 5 * FROM sys.tables" />

    <!-- ============================================================
         Entra ID sign-in (OWIN OpenID Connect) for per-user Fabric RLS.
         The app signs the user in, then acquires a Fabric SQL token ON
         BEHALF OF that user (MSAL) so Fabric applies row-level security.
         Set ida:ClientSecret as an App Service application setting in
         production - do NOT commit the real secret here.
         ============================================================ -->
    <add key="owin:AppStartup" value="Startup" />
    <add key="ida:ClientId" value="<<your-client-id>>" />
    <add key="ida:TenantId" value="<<your-tenant-id>>" />
    <add key="ida:ClientSecret" value="" />
    <add key="ida:RedirectUri" value="https://<<your-webapp>>.azurewebsites.net/" />
    <add key="ida:SqlScope" value="https://database.windows.net/user_impersonation" />
  </appSettings>

  <system.web>
    <compilation debug="false" strict="false" explicit="true" targetFramework="4.8">
      <assemblies>
        <add assembly="System.Data.Common, Version=4.2.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a" />
      </assemblies>
    </compilation>
    <httpRuntime targetFramework="4.8" />
    <authentication mode="None" />
    <customErrors mode="RemoteOnly" />
  </system.web>

  <!--
    Assembly binding redirects. On .NET Framework these are essential: mismatched
    versions of the identity/runtime assemblies pulled in by Microsoft.Data.SqlClient
    7.0.2 cause "Could not load file or assembly" errors that look like connection
    failures. The values below are a starter set - after NuGet restore, let Visual
    Studio regenerate/complete them (autoGenerateBindingRedirects=true) so the
    versions match exactly what was restored.
  -->
  <runtime>
    <autoGenerateBindingRedirects>true</autoGenerateBindingRedirects>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Azure.Core" publicKeyToken="92742159e12e44c8" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-999.0.0.0" newVersion="1.51.1.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Azure.Identity" publicKeyToken="92742159e12e44c8" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-999.0.0.0" newVersion="1.18.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.Bcl.AsyncInterfaces" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-999.0.0.0" newVersion="8.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.Bcl.Cryptography" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-999.0.0.0" newVersion="8.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.Bcl.TimeProvider" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
