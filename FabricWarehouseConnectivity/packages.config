<?xml version="1.0" encoding="utf-8"?>
<packages>
  <!--
    Direct dependency. Restoring this package via NuGet will also bring in the
    transitive dependencies required for Microsoft Entra ID authentication on
    .NET Framework 4.8 (Azure.Identity, Microsoft.Identity.Client,
    Microsoft.IdentityModel.*, Microsoft.Data.SqlClient.SNI, etc.).

    After restore, let Visual Studio auto-generate the binding redirects in
    Web.config (autoGenerateBindingRedirects=true). Missing redirects are a
    common cause of runtime assembly-load failures that look like connection
    problems.
  -->
  <package id="Microsoft.Data.SqlClient" version="7.0.2" targetFramework="net48" />

  <!--
    REQUIRED for Microsoft.Data.SqlClient 7.0+. As of v7.0 the Microsoft Entra ID
    (Active Directory) authentication providers were moved OUT of the core package
    into this extension package. Without it, any connection using
    "Authentication=Active Directory ..." fails at runtime with:
        "Cannot find an authentication provider for 'ActiveDirectoryServicePrincipal'"
    This is the most common cause of Fabric connection failures on 7.0.x.
    It also pulls in Azure.Identity (>= 1.18.0).
  -->
  <package id="Microsoft.Data.SqlClient.Extensions.Azure" version="7.0.2" targetFramework="net48" />
  <package id="Azure.Identity" version="1.18.0" targetFramework="net48" />

  <!--
    Entra ID sign-in (OWIN OpenID Connect) + on-behalf-of token acquisition (MSAL)
    used by the home page for per-user row-level security.
  -->
  <package id="Microsoft.Owin.Security.OpenIdConnect" version="4.2.3" targetFramework="net48" />
  <package id="Microsoft.Owin.Security.Cookies" version="4.2.3" targetFramework="net48" />
  <package id="Microsoft.Owin.Host.SystemWeb" version="4.2.3" targetFramework="net48" />
  <package id="Microsoft.Identity.Client" version="4.84.2" targetFramework="net48" />
</packages>
